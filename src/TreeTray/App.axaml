<Application
    x:Class="TreeTray.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://Avalonia.Controls.ColorPicker/Themes/Fluent/Fluent.xaml" />

    <Style Selector="Window">
      <Setter Property="Background" Value="#F4F4EE" />
      <Setter Property="Foreground" Value="#1E261D" />
    </Style>

    <Style Selector="Border.card">
      <Setter Property="Background" Value="#FCFCF7" />
      <Setter Property="CornerRadius" Value="24" />
      <Setter Property="BorderBrush" Value="#D9DDD1" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="BoxShadow" Value="0 10 30 0 #14000000" />
    </Style>

    <Style Selector="TextBlock.section-title">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#20311C" />
    </Style>

    <Style Selector="TextBlock.meta-label">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="#5A6756" />
    </Style>

    <Style Selector="TextBlock.meta-value">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#243121" />
    </Style>

    <Style Selector="Button.toolbar">
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Margin" Value="0,0,10,0" />
    </Style>
  </Application.Styles>
</Application>
